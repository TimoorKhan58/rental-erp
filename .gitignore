# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies — installed packages; reproducible via package-lock.json
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing — coverage reports generated by test runners
/coverage

# Next.js — build cache and static export output
/.next/
/out/

# Production — compiled output directories
/build
/dist

# Environment — secrets and local overrides; never commit credentials
.env
.env.local
.env*.local
.env.docker
.env.production
.env.staging

# TLS private material (placeholders/docs under nginx/certs stay tracked)
nginx/certs/*.pem
nginx/certs/*.key
nginx/certs/*.crt
!nginx/certs/README.md
!nginx/certs/.gitkeep

# Logs — runtime and package-manager log files
/logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Misc — OS artifacts and local certificates
.DS_Store
*.pem

# Vercel — local deployment configuration
.vercel

# TypeScript — incremental build info and auto-generated declarations
*.tsbuildinfo
next-env.d.ts

# Prisma — generated client (regenerated via `npx prisma generate`)
/src/generated/

/src/generated/prisma

# Database backups — never commit dumps
/backups
*.sql.gz
*.sql.zip

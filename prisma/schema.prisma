// Prisma schema — Rental ERP (M3-FINAL-FIX)
// Docs: https://pris.ly/d/prisma-schema
//
// Service-layer validation (not enforced in Prisma):
// - quantity > 0 (RentalOrderItem, DispatchItem, RepairItem, ReturnInspectionItem, etc.)
// - amount >= 0 (Payment, Expense, and other monetary fields)
// - repairCost >= 0 (RepairItem)
// - width > 0, height > 0 (DashboardWidget)
// - paddingLength > 0, currentNumber >= startingNumber (DocumentSequence)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Better Auth (session provider) ────────────────────────────
//
// Canonical credentials and sessions. Linked to ERP users via erpUserId / authUserId.

model AuthUser {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  role          String        @default("viewer")
  erpUserId     String?       @unique @db.Uuid
  erpUser       User?         @relation("AuthUserToErpUser", fields: [erpUserId], references: [id], onDelete: SetNull)
  linkedErpUser User?         @relation("ErpUserToAuthUser")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      AuthSession[]
  accounts      AuthAccount[]

  @@map("user")
}

model AuthSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model AuthVerification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

// ── Access control ────────────────────────────────────────────
//
// Soft delete (deletedAt, deletedBy) is planned for a future production phase
// after business approval. Not implemented in the current schema freeze.

model Role {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id                     String                 @id @default(uuid()) @db.Uuid
  name                   String
  email                  String                 @unique
  passwordHash           String?
  authUserId             String?                @unique
  authUser               AuthUser?              @relation("ErpUserToAuthUser", fields: [authUserId], references: [id], onDelete: SetNull)
  linkedAuthUser         AuthUser?              @relation("AuthUserToErpUser")
  roleId                 String                 @db.Uuid
  role                   Role                   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive               Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  inventoryTransactions  InventoryTransaction[]
  rentalOrders           RentalOrder[]
  dispatches             Dispatch[]
  returnInspections      ReturnInspection[]
  repairs                Repair[]
  maintenances           Maintenance[]
  rentalInvoices         RentalInvoice[]
  createdPayments        Payment[]
  createdJournalEntries  JournalEntry[] @relation("JournalEntryCreatedBy")
  postedJournalEntries   JournalEntry[] @relation("JournalEntryPostedBy")
  recordedExpenses       Expense[]               @relation("ExpenseRecordedBy")
  approvedExpenses       Expense[]               @relation("ExpenseApprovedBy")
  paidExpenses           Expense[]               @relation("ExpensePaidBy")
  auditLogs              AuditLog[]
  notificationRecipients NotificationRecipient[]
  userDashboards         UserDashboard[]
  createdAssets          Asset[]                 @relation("AssetCreatedBy")
  assignedAssets         Asset[]                 @relation("AssetAssignedTo")
  disposedAssets         Asset[]                 @relation("AssetDisposedBy")
  assetTransfers         AssetTransfer[]
  assetMaintenanceRecords AssetMaintenanceHistory[]

  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

// ── Customers ─────────────────────────────────────────────────
//
// Soft delete (deletedAt, deletedBy) is planned for a future production phase
// after business approval. Not implemented in the current schema freeze.

model Customer {
  id           String   @id @default(uuid()) @db.Uuid
  customerCode String   @unique
  name         String
  phone        String   @unique
  cnic         String?
  address      String
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rentalOrders   RentalOrder[]
  rentalInvoices RentalInvoice[]
  payments       Payment[]

  @@index([name])
  @@index([isActive])
  @@map("customers")
}

// ── Suppliers ─────────────────────────────────────────────────
//
// Soft delete (deletedAt, deletedBy) is planned for a future production phase
// after business approval. Not implemented in the current schema freeze.

model Supplier {
  id           String   @id @default(uuid()) @db.Uuid
  supplierCode String   @unique
  name         String
  phone        String   @unique
  email        String?
  address      String
  notes        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  assets         Asset[]
  expenses       Expense[]

  @@index([name])
  @@index([isActive])
  @@map("suppliers")
}

// ── Warehouses ──────────────────────────────────────────────────
//
// Soft delete (deletedAt, deletedBy) is planned for a future production phase
// after business approval. Not implemented in the current schema freeze.

model Warehouse {
  id            String   @id @default(uuid()) @db.Uuid
  warehouseCode String   @unique
  name          String
  description   String?
  address       String?
  contactPerson String?
  phone         String?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt      DateTime        @updatedAt
  inventories    Inventory[]
  purchaseOrders PurchaseOrder[]
  rentalOrders   RentalOrder[]
  repairs              Repair[]
  maintenances         Maintenance[]
  assets               Asset[]
  assetTransfersFrom   AssetTransfer[] @relation("AssetTransferFrom")
  assetTransfersTo     AssetTransfer[] @relation("AssetTransferTo")

  @@index([name])
  @@index([isActive])
  @@map("warehouses")
}

// ── Catalog ─────────────────────────────────────────────────────
//
// Soft delete (deletedAt, deletedBy) is planned for a future production phase
// after business approval. Not implemented in the current schema freeze.

enum AttributeDataType {
  TEXT
  NUMBER
  BOOLEAN
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@map("categories")
}

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@map("brands")
}

model UnitOfMeasure {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@map("units_of_measure")
}

model ProductAttribute {
  id        String              @id @default(uuid()) @db.Uuid
  name      String              @unique
  dataType  AttributeDataType   @default(TEXT)
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  values    ProductAttributeValue[]

  @@index([isActive])
  @@map("product_attributes")
}

model ProductTag {
  id          String                 @id @default(uuid()) @db.Uuid
  name        String                 @unique
  color       String?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  assignments ProductTagAssignment[]

  @@index([isActive])
  @@map("product_tags")
}

model ProductTagAssignment {
  productId String     @db.Uuid
  tagId     String     @db.Uuid
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag       ProductTag @relation(fields: [tagId], references: [id], onDelete: Restrict)
  createdAt DateTime   @default(now())

  @@id([productId, tagId])
  @@index([tagId])
  @@map("product_tag_assignments")
}

model ProductImage {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_images")
}

model ProductSpecification {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, key])
  @@index([productId])
  @@map("product_specifications")
}

model ProductAttributeValue {
  id          String           @id @default(uuid()) @db.Uuid
  productId   String           @db.Uuid
  attributeId String           @db.Uuid
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Restrict)
  value       String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([productId, attributeId])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model ProductVariant {
  id        String   @id @default(uuid()) @db.Uuid
  productId String   @db.Uuid
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@map("product_variants")
}

model Product {
  id                String    @id @default(uuid()) @db.Uuid
  productCode       String    @unique
  categoryId        String?   @db.Uuid
  category          Category? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brandId           String?   @db.Uuid
  brand             Brand?    @relation(fields: [brandId], references: [id], onDelete: Restrict)
  unitId            String?   @db.Uuid
  unitOfMeasure     UnitOfMeasure? @relation(fields: [unitId], references: [id], onDelete: Restrict)
  name              String
  description       String?
  purchaseCost      Decimal   @db.Decimal(12, 2)
  rentalPricePerDay Decimal   @db.Decimal(12, 2)
  totalQuantity     Int       @default(0)
  minimumStock      Int       @default(0)
  unit              String
  isRentable        Boolean   @default(true)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  inventories          Inventory[]
  purchaseOrderItems   PurchaseOrderItem[]
  rentalOrderItems     RentalOrderItem[]
  dispatchItems        DispatchItem[]
  repairItems          RepairItem[]
  repairs              Repair[]
  maintenances         Maintenance[]
  tagAssignments       ProductTagAssignment[]
  images               ProductImage[]
  specifications       ProductSpecification[]
  attributeValues      ProductAttributeValue[]
  variants             ProductVariant[]

  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([name])
  @@index([productCode])
  @@index([isActive])
  @@map("products")
}

// ── Inventory ───────────────────────────────────────────────────

enum StockMovementType {
  IN
  OUT
  RESERVE
  RELEASE
  ADJUSTMENT
}

model Inventory {
  id               String                 @id @default(uuid()) @db.Uuid
  productId        String                 @db.Uuid
  product          Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId      String                 @db.Uuid
  warehouse        Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  quantityOnHand   Int
  reservedQuantity Int                    @default(0)
  minimumStock     Int                    @default(0)
  maximumStock     Int?
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  transactions     InventoryTransaction[]
  maintenances     Maintenance[]

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@index([isActive])
  @@map("inventory")
}

model InventoryTransaction {
  id               String            @id @default(uuid()) @db.Uuid
  inventoryId      String            @db.Uuid
  inventory        Inventory         @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  productId        String            @db.Uuid
  warehouseId      String            @db.Uuid
  movementType     StockMovementType
  quantity         Int
  previousQuantity Int
  newQuantity      Int
  referenceType    String?
  referenceId      String?
  remarks          String            @default("")
  createdAt        DateTime          @default(now())
  createdById      String            @db.Uuid
  createdBy        User              @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([inventoryId])
  @@index([productId])
  @@index([warehouseId])
  @@index([movementType])
  @@index([createdAt])
  @@map("inventory_transactions")
}

// ── Procurement ─────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           String                @id @default(uuid()) @db.Uuid
  poNumber     String                @unique
  supplierId   String                @db.Uuid
  supplier     Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouseId  String                @db.Uuid
  warehouse    Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  status       PurchaseOrderStatus   @default(DRAFT)
  orderDate    DateTime
  expectedDate DateTime?
  remarks      String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  items        PurchaseOrderItem[]

  @@index([status])
  @@index([supplierId])
  @@index([warehouseId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String        @id @default(uuid()) @db.Uuid
  purchaseOrderId  String        @db.Uuid
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String        @db.Uuid
  product          Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity         Int
  unitCost         Decimal       @db.Decimal(12, 2)
  receivedQuantity Int           @default(0)

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

// ── Rental orders ───────────────────────────────────────────────

enum RentalOrderStatus {
  DRAFT
  CONFIRMED
  RESERVED
  DISPATCHED
  ON_RENT
  PARTIALLY_RETURNED
  RETURNED
  COMPLETED
  CANCELLED
}

model RentalOrder {
  id                 String             @id @default(uuid()) @db.Uuid
  orderNumber        String             @unique
  customerId         String             @db.Uuid
  customer           Customer           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  warehouseId        String             @db.Uuid
  warehouse          Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  status             RentalOrderStatus  @default(DRAFT)
  bookingDate        DateTime           @db.Date
  eventStartDate     DateTime           @db.Date
  eventEndDate       DateTime           @db.Date
  expectedReturnDate DateTime           @db.Date
  actualReturnDate   DateTime?          @db.Date
  deliveryRequired   Boolean
  deliveryAddress    String
  deliveryCharges    Decimal            @db.Decimal(12, 2)
  labourCharges      Decimal            @db.Decimal(12, 2)
  discount           Decimal            @db.Decimal(12, 2)
  notes              String?
  subtotal           Decimal            @db.Decimal(12, 2)
  grandTotal         Decimal            @db.Decimal(12, 2)
  createdById        String             @db.Uuid
  createdBy          User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  items              RentalOrderItem[]
  dispatches         Dispatch[]
  returnInspections  ReturnInspection[]
  rentalInvoices     RentalInvoice[]

  @@index([customerId])
  @@index([warehouseId])
  @@index([status])
  @@index([customerId, status])
  @@index([eventStartDate])
  @@index([eventEndDate])
  @@map("rental_orders")
}

model RentalOrderItem {
  id                String      @id @default(uuid()) @db.Uuid
  rentalOrderId     String      @db.Uuid
  rentalOrder       RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Restrict)
  productId         String      @db.Uuid
  product           Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity          Int
  rentalPricePerDay Decimal     @db.Decimal(12, 2)
  reservedQuantity  Int         @default(0)
  numberOfDays      Int
  lineTotal         Decimal     @db.Decimal(12, 2)
  notes             String?
  dispatchItems         DispatchItem[]
  returnInspectionItems ReturnInspectionItem[]

  @@index([rentalOrderId])
  @@index([productId])
  @@map("rental_order_items")
}

// ── Dispatch & delivery ─────────────────────────────────────────

enum DeliveryMethod {
  DELIVERY
  CUSTOMER_PICKUP
}

enum DispatchStatus {
  DRAFT
  READY
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Dispatch {
  id              String         @id @default(uuid()) @db.Uuid
  dispatchNumber  String         @unique
  rentalOrderId   String         @db.Uuid
  rentalOrder     RentalOrder    @relation(fields: [rentalOrderId], references: [id], onDelete: Restrict)
  dispatchDate    DateTime
  deliveryMethod  DeliveryMethod
  // Future architecture: vehicleNumber will migrate to a dedicated Vehicle module.
  // driverName and driverPhone will migrate to dedicated Employee and Driver modules.
  // These free-text fields are retained until those modules are implemented.
  /// Temporary free-text fields — will migrate to dedicated Vehicle and Driver modules.
  vehicleNumber   String?
  /// Temporary free-text fields — will migrate to dedicated Employee and Driver modules.
  driverName      String?
  /// Temporary free-text fields — will migrate to dedicated Employee and Driver modules.
  driverPhone     String?
  deliveryAddress String
  remarks         String?
  status          DispatchStatus @default(DRAFT)
  loadedAt        DateTime?
  departedAt      DateTime?
  deliveredAt     DateTime?
  createdById     String         @db.Uuid
  createdBy       User           @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           DispatchItem[]
  returnInspections ReturnInspection[]

  @@index([rentalOrderId])
  @@index([dispatchDate])
  @@index([status])
  @@map("dispatches")
}

model DispatchItem {
  id                String           @id @default(uuid()) @db.Uuid
  dispatchId        String           @db.Uuid
  dispatch          Dispatch         @relation(fields: [dispatchId], references: [id], onDelete: Restrict)
  productId         String           @db.Uuid
  product           Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  rentalOrderItemId String?          @db.Uuid
  rentalOrderItem   RentalOrderItem? @relation(fields: [rentalOrderItemId], references: [id], onDelete: Restrict)
  quantity          Int
  notes             String?

  @@index([dispatchId])
  @@index([productId])
  @@map("dispatch_items")
}

// ── Return & inspection ─────────────────────────────────────────

enum ReturnStatus {
  DRAFT
  RECEIVED
  INSPECTED
  COMPLETED
  CANCELLED
}

model ReturnInspection {
  id             String                 @id @default(uuid()) @db.Uuid
  returnNumber   String                 @unique
  rentalOrderId  String                 @db.Uuid
  rentalOrder    RentalOrder            @relation(fields: [rentalOrderId], references: [id], onDelete: Restrict)
  dispatchId     String                 @db.Uuid
  dispatch       Dispatch               @relation(fields: [dispatchId], references: [id], onDelete: Restrict)
  inspectionDate DateTime
  inspectedById  String                 @db.Uuid
  inspectedBy    User                   @relation(fields: [inspectedById], references: [id], onDelete: Restrict)
  remarks        String?
  status         ReturnStatus           @default(DRAFT)
  receivedAt     DateTime?
  inspectedAt    DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  items          ReturnInspectionItem[]
  repairs        Repair[]

  @@index([rentalOrderId])
  @@index([dispatchId])
  @@index([inspectionDate])
  @@index([status])
  @@map("return_inspections")
}

model ReturnInspectionItem {
  id                 String           @id @default(uuid()) @db.Uuid
  returnInspectionId String           @db.Uuid
  returnInspection   ReturnInspection @relation(fields: [returnInspectionId], references: [id], onDelete: Restrict)
  rentalOrderItemId  String           @db.Uuid
  rentalOrderItem    RentalOrderItem  @relation(fields: [rentalOrderItemId], references: [id], onDelete: Restrict)
  returnedQuantity   Int
  goodQuantity       Int
  brokenQuantity     Int
  repairQuantity     Int
  lostQuantity       Int
  missingQuantity    Int
  damageCharge       Decimal          @db.Decimal(12, 2)
  notes              String?

  @@map("return_inspection_items")
}

// ── Repair management ───────────────────────────────────────────

enum RepairStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  WRITE_OFF
}

enum RepairType {
  CLEANING
  WELDING
  STITCHING
  PAINTING
  FRAME_REPAIR
  FABRIC_REPAIR
  OTHER
}

model Repair {
  id                     String           @id @default(uuid()) @db.Uuid
  repairNumber           String           @unique
  returnInspectionId     String           @db.Uuid
  returnInspection       ReturnInspection @relation(fields: [returnInspectionId], references: [id], onDelete: Restrict)
  returnInspectionItemId String           @db.Uuid
  productId              String           @db.Uuid
  product                Product          @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId            String           @db.Uuid
  warehouse              Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  quantity               Int
  repairDate             DateTime
  assignedTo             String?
  estimatedCost          Decimal          @default(0) @db.Decimal(12, 2)
  actualCost             Decimal          @default(0) @db.Decimal(12, 2)
  status                 RepairStatus     @default(PENDING)
  remarks                String?
  startedAt              DateTime?
  completedAt            DateTime?
  createdById            String           @db.Uuid
  createdBy              User             @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  items                  RepairItem[]

  @@index([repairDate])
  @@index([status])
  @@index([returnInspectionId])
  @@index([returnInspectionItemId])
  @@index([productId])
  @@index([warehouseId])
  @@map("repairs")
}

model RepairItem {
  id         String     @id @default(uuid()) @db.Uuid
  repairId   String     @db.Uuid
  repair     Repair     @relation(fields: [repairId], references: [id], onDelete: Restrict)
  productId  String     @db.Uuid
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity   Int
  repairType RepairType
  repairCost Decimal    @db.Decimal(12, 2)
  remarks    String?

  @@index([repairId])
  @@index([productId])
  @@map("repair_items")
}

// ── Maintenance / Service Jobs ────────────────────────────────────

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceServiceType {
  PREVENTIVE
  CLEANING
  INSPECTION
  CALIBRATION
  LUBRICATION
  OTHER
}

model Maintenance {
  id                 String                 @id @default(uuid()) @db.Uuid
  maintenanceNumber  String                 @unique
  productId          String                 @db.Uuid
  product            Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouseId        String                 @db.Uuid
  warehouse          Warehouse              @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  inventoryId        String                 @db.Uuid
  inventory          Inventory              @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  quantity           Int
  serviceType        MaintenanceServiceType
  technician         String?
  vendor             String?
  scheduledDate      DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  estimatedCost      Decimal                @default(0) @db.Decimal(12, 2)
  actualCost         Decimal                @default(0) @db.Decimal(12, 2)
  notes              String?
  status             MaintenanceStatus      @default(SCHEDULED)
  createdById        String                 @db.Uuid
  createdBy          User                   @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([maintenanceNumber])
  @@index([productId])
  @@index([warehouseId])
  @@index([inventoryId])
  @@index([scheduledDate])
  @@index([status])
  @@map("maintenances")
}

// ── Rental Invoicing ──────────────────────────────────────────────

enum RentalInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  VOID
}

enum RentalInvoiceLineType {
  RENTAL_CHARGE
  DELIVERY_CHARGE
  PICKUP_CHARGE
  DAMAGE_CHARGE
  LOST_ITEM_CHARGE
  REPAIR_CHARGE
  MANUAL_CHARGE
  DISCOUNT
  TAX
}

model RentalInvoice {
  id            String              @id @default(uuid()) @db.Uuid
  invoiceNumber String              @unique
  rentalOrderId String              @db.Uuid
  rentalOrder   RentalOrder         @relation(fields: [rentalOrderId], references: [id], onDelete: Restrict)
  customerId    String              @db.Uuid
  customer      Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoiceDate   DateTime            @db.Date
  dueDate       DateTime?           @db.Date
  subtotal      Decimal             @db.Decimal(12, 2)
  discount      Decimal             @db.Decimal(12, 2)
  tax           Decimal             @db.Decimal(12, 2)
  grandTotal    Decimal             @db.Decimal(12, 2)
  paidAmount    Decimal             @default(0) @db.Decimal(12, 2)
  balance       Decimal             @db.Decimal(12, 2)
  status        RentalInvoiceStatus @default(DRAFT)
  notes         String?
  issuedAt      DateTime?
  voidedAt      DateTime?
  createdById   String              @db.Uuid
  createdBy     User                @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         RentalInvoiceItem[]
  payments      Payment[]

  @@index([invoiceNumber])
  @@index([rentalOrderId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([status])
  @@index([customerId, status])
  @@map("rental_invoices")
}

model RentalInvoiceItem {
  id              String                @id @default(uuid()) @db.Uuid
  rentalInvoiceId String                @db.Uuid
  rentalInvoice   RentalInvoice         @relation(fields: [rentalInvoiceId], references: [id], onDelete: Cascade)
  lineType        RentalInvoiceLineType
  description     String
  quantity        Int
  unitPrice       Decimal               @db.Decimal(12, 2)
  lineTotal       Decimal               @db.Decimal(12, 2)
  sortOrder       Int                   @default(0)

  @@index([rentalInvoiceId])
  @@map("rental_invoice_items")
}

// ── Payments ────────────────────────────────────────────────────

enum PaymentStatus {
  PENDING
  POSTED
  VOID
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHEQUE
  CARD
  ONLINE
  OTHER
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  paymentNumber   String        @unique
  rentalInvoiceId String        @db.Uuid
  rentalInvoice   RentalInvoice @relation(fields: [rentalInvoiceId], references: [id], onDelete: Restrict)
  customerId      String        @db.Uuid
  customer        Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  paymentDate     DateTime
  paymentMethod   PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  isRefund        Boolean       @default(false)
  referenceNumber String?
  notes           String?
  status          PaymentStatus @default(PENDING)
  postedAt        DateTime?
  voidedAt        DateTime?
  createdById     String        @db.Uuid
  createdBy       User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([paymentNumber])
  @@index([paymentDate])
  @@index([paymentMethod])
  @@index([status])
  @@index([rentalInvoiceId])
  @@index([customerId])
  @@index([rentalInvoiceId, paymentDate])
  @@map("payments")
}

// ── Accounting / General Ledger ───────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum JournalReferenceType {
  RENTAL_INVOICE
  PAYMENT
  MANUAL
  OTHER
}

model Account {
  id           String             @id @default(uuid()) @db.Uuid
  accountCode  String             @unique
  name         String
  accountType  AccountType
  description  String?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  journalLines JournalEntryLine[]

  @@index([accountCode])
  @@index([accountType])
  @@index([isActive])
  @@map("accounts")
}

model JournalEntry {
  id            String                @id @default(uuid()) @db.Uuid
  journalNumber String                @unique
  journalDate   DateTime              @db.Date
  description   String
  referenceType JournalReferenceType?
  referenceId   String?               @db.Uuid
  status        JournalEntryStatus    @default(DRAFT)
  postedAt      DateTime?
  voidedAt      DateTime?
  createdById   String                @db.Uuid
  createdBy     User                  @relation("JournalEntryCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  postedById    String?               @db.Uuid
  postedBy      User?                 @relation("JournalEntryPostedBy", fields: [postedById], references: [id], onDelete: Restrict)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  lines         JournalEntryLine[]
  expenses      Expense[]

  @@index([journalNumber])
  @@index([journalDate])
  @@index([status])
  @@index([referenceType, referenceId])
  @@map("journal_entries")
}

model JournalEntryLine {
  id             String       @id @default(uuid()) @db.Uuid
  journalEntryId String       @db.Uuid
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  accountId      String       @db.Uuid
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  debit          Decimal      @default(0) @db.Decimal(12, 2)
  credit         Decimal      @default(0) @db.Decimal(12, 2)
  memo           String?
  sortOrder      Int          @default(0)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ── Expenses ────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum ExpenseType {
  VENDOR
  MANUAL
}

model ExpenseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expenses    Expense[]

  @@index([isActive])
  @@map("expense_categories")
}

model Expense {
  id              String          @id @default(uuid()) @db.Uuid
  expenseNumber   String          @unique
  expenseDate     DateTime
  categoryId      String          @db.Uuid
  category        ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  expenseType     ExpenseType
  status          ExpenseStatus   @default(DRAFT)
  amount          Decimal         @db.Decimal(12, 2)
  paymentMethod   PaymentMethod?
  supplierId      String?         @db.Uuid
  supplier        Supplier?       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  vendorName      String?
  description     String
  notes           String?
  attachmentRef   String?
  referenceNumber String?
  rejectionReason String?
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  paidAt          DateTime?
  journalEntryId  String?         @db.Uuid
  journalEntry    JournalEntry?   @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)
  recordedById    String          @db.Uuid
  recordedBy      User            @relation("ExpenseRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)
  approvedById    String?         @db.Uuid
  approvedBy      User?           @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)
  paidById        String?         @db.Uuid
  paidBy          User?           @relation("ExpensePaidBy", fields: [paidById], references: [id], onDelete: Restrict)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([expenseDate])
  @@index([status])
  @@index([categoryId])
  @@index([supplierId])
  @@index([expenseDate, status])
  @@map("expenses")
}

// ── Company settings ────────────────────────────────────────────
//
// createdBy / updatedBy audit fields may be introduced in a future phase if
// enhanced configuration auditing becomes a business requirement.

enum DocumentType {
  RENTAL_ORDER
  PAYMENT
  DISPATCH
  EXPENSE
  REPAIR
  CUSTOMER
  PRODUCT
}

model CompanySetting {
  id                     String             @id @default(uuid()) @db.Uuid
  companyName            String
  businessName           String
  ownerName              String?
  phone                  String
  secondaryPhone         String?
  email                  String
  website                String?
  address                String
  city                   String
  province               String
  country                String
  postalCode             String?
  ntn                    String?
  strn                   String?
  logoUrl                String?
  faviconUrl             String?
  currencyCode           String
  currencySymbol         String
  timezone               String
  language               String
  dateFormat             String
  timeFormat             String
  numberFormat           String
  defaultRentalDays      Int
  defaultTaxPercentage   Decimal            @db.Decimal(5, 2)
  fiscalYearStartMonth   Int                @default(1)
  securityDepositEnabled Boolean            @default(false)
  lateFeeEnabled         Boolean            @default(false)
  isActive               Boolean            @default(true)
  setupCompleted         Boolean            @default(false)
  maintenanceMode        Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  documentSequences      DocumentSequence[]

  @@map("company_settings")
}

model DocumentSequence {
  id               String         @id @default(uuid()) @db.Uuid
  companySettingId String         @db.Uuid
  companySetting   CompanySetting @relation(fields: [companySettingId], references: [id], onDelete: Restrict)
  documentType     DocumentType
  prefix           String
  suffix           String?
  startingNumber   Int
  currentNumber    Int
  paddingLength    Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([companySettingId, documentType])
  @@map("document_sequences")
}

// ── System settings ─────────────────────────────────────────────
//
// createdBy / updatedBy audit fields may be introduced in a future phase if
// enhanced configuration auditing becomes a business requirement.

enum Environment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum BackupFrequency {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
}

model SystemSetting {
  id                         String          @id @default(uuid()) @db.Uuid
  appName                    String
  appVersion                 String
  environment                Environment     @default(DEVELOPMENT)
  supportEmail               String?
  supportPhone               String?
  minPasswordLength          Int             @default(8)
  maxLoginAttempts           Int             @default(5)
  lockoutDurationMinutes     Int             @default(30)
  requireEmailVerification   Boolean         @default(false)
  allowPasswordReset         Boolean         @default(true)
  sessionTimeoutMinutes      Int             @default(60)
  rememberMeDurationDays     Int             @default(7)
  maxConcurrentSessions      Int             @default(3)
  passwordExpiryDays         Int?
  ipWhitelistEnabled         Boolean         @default(false)
  auditLogRetentionDays      Int             @default(90)
  maxUploadSizeMb            Int             @default(10)
  allowedFileTypes           String
  uploadStoragePath          String?
  emailNotificationsEnabled  Boolean         @default(true)
  smsNotificationsEnabled    Boolean         @default(false)
  defaultNotificationEmail   String?
  backupEnabled              Boolean         @default(false)
  backupFrequency            BackupFrequency @default(DAILY)
  backupRetentionDays        Int             @default(30)
  lastBackupAt               DateTime?
  defaultDashboardView       String          @default("overview")
  recentItemsLimit           Int             @default(10)
  chartDefaultPeriodDays     Int             @default(30)
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  featureFlags               FeatureFlag[]

  @@map("system_settings")
}

model FeatureFlag {
  id              String        @id @default(uuid()) @db.Uuid
  systemSettingId String        @db.Uuid
  systemSetting   SystemSetting @relation(fields: [systemSettingId], references: [id], onDelete: Restrict)
  featureKey      String
  displayName     String
  enabled         Boolean       @default(false)
  description     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([systemSettingId, featureKey])
  @@index([featureKey])
  @@index([enabled])
  @@map("feature_flags")
}

// ── Audit log ───────────────────────────────────────────────────

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  FAILED_LOGIN
  PASSWORD_CHANGED
  PASSWORD_RESET
  APPROVE
  REJECT
  CANCEL
  DISPATCH
  RETURN
  PAYMENT_RECEIVED
  EXPENSE_RECORDED
  EXPORT
  IMPORT
  PRINT
}

enum AuditStatus {
  SUCCESS
  FAILED
  WARNING
}

model AuditLog {
  id           String      @id @default(uuid()) @db.Uuid
  userId       String?     @db.Uuid
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  module       String
  entityName   String
  recordId     String
  action       AuditAction
  status       AuditStatus
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  httpMethod   String?
  route        String?
  errorMessage String?
  createdAt    DateTime    @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([module])
  @@index([entityName])
  @@index([recordId])
  @@index([action])
  @@index([status])
  @@index([requestId])
  @@map("audit_logs")
}

// ── Notifications ───────────────────────────────────────────────
//
// createdBy / updatedBy audit fields may be introduced in a future phase if
// enhanced configuration auditing becomes a business requirement.

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model NotificationTemplate {
  id            String               @id @default(uuid()) @db.Uuid
  name          String
  eventKey      String               @unique
  channel       NotificationChannel
  subject       String?
  title         String
  body          String
  enabled       Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  notifications Notification[]

  @@map("notification_templates")
}

model Notification {
  id             String                 @id @default(uuid()) @db.Uuid
  templateId     String?                @db.Uuid
  template       NotificationTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel        NotificationChannel
  status         NotificationStatus     @default(PENDING)
  priority       NotificationPriority   @default(NORMAL)
  module         String
  entityName     String
  recordId       String
  subject        String
  title          String
  body           String
  scheduledAt    DateTime?
  sentAt         DateTime?
  deliveredAt    DateTime?
  failedAt       DateTime?
  retryCount     Int                    @default(0)
  failureReason  String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  recipients     NotificationRecipient[]

  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
  @@index([sentAt])
  @@index([module])
  @@index([entityName])
  @@index([recordId])
  @@map("notifications")
}

model NotificationRecipient {
  id                String       @id @default(uuid()) @db.Uuid
  notificationId    String       @db.Uuid
  notification      Notification @relation(fields: [notificationId], references: [id], onDelete: Restrict)
  userId            String?      @db.Uuid
  user              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  recipientName     String
  recipientEmail    String?
  recipientPhone    String?
  recipientWhatsApp String?
  isRead            Boolean      @default(false)
  readAt            DateTime?
  createdAt         DateTime     @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notification_recipients")
}

// ── Asset Management ────────────────────────────────────────────
//
// Company-owned assets (vehicles, machinery, tools, etc.) separate from rental inventory.

enum AssetStatus {
  ACTIVE
  UNDER_MAINTENANCE
  TRANSFERRED
  DISPOSED
}

model AssetCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]

  @@index([isActive])
  @@map("asset_categories")
}

model Asset {
  id                 String      @id @default(uuid()) @db.Uuid
  assetCode          String      @unique
  name               String
  categoryId         String      @db.Uuid
  category           AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  serialNumber       String?
  purchaseDate       DateTime    @db.Date
  purchaseCost       Decimal     @db.Decimal(12, 2)
  residualValue      Decimal     @db.Decimal(12, 2)
  usefulLifeMonths   Int
  currentBookValue   Decimal     @db.Decimal(12, 2)
  warehouseId        String      @db.Uuid
  warehouse          Warehouse   @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  assignedEmployeeId String?     @db.Uuid
  assignedEmployee   User?       @relation("AssetAssignedTo", fields: [assignedEmployeeId], references: [id], onDelete: SetNull)
  vendorId           String?     @db.Uuid
  vendor             Supplier?   @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  notes              String?
  status             AssetStatus @default(ACTIVE)
  disposalDate       DateTime?   @db.Date
  disposalAmount     Decimal?    @db.Decimal(12, 2)
  disposalReason     String?
  disposedById       String?     @db.Uuid
  disposedBy         User?       @relation("AssetDisposedBy", fields: [disposedById], references: [id], onDelete: SetNull)
  createdById        String      @db.Uuid
  createdBy          User        @relation("AssetCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  transfers          AssetTransfer[]
  maintenanceHistory AssetMaintenanceHistory[]

  @@index([categoryId])
  @@index([warehouseId])
  @@index([status])
  @@index([assetCode])
  @@index([name])
  @@map("assets")
}

model AssetTransfer {
  id              String    @id @default(uuid()) @db.Uuid
  assetId         String    @db.Uuid
  asset           Asset     @relation(fields: [assetId], references: [id], onDelete: Restrict)
  fromWarehouseId String    @db.Uuid
  fromWarehouse   Warehouse @relation("AssetTransferFrom", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouseId   String    @db.Uuid
  toWarehouse     Warehouse @relation("AssetTransferTo", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  transferDate    DateTime  @db.Date
  reason          String?
  transferredById String    @db.Uuid
  transferredBy   User      @relation(fields: [transferredById], references: [id], onDelete: Restrict)
  createdAt       DateTime  @default(now())

  @@index([assetId])
  @@index([transferDate])
  @@map("asset_transfers")
}

model AssetMaintenanceHistory {
  id            String   @id @default(uuid()) @db.Uuid
  assetId       String   @db.Uuid
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)
  serviceDate   DateTime @db.Date
  vendor        String?
  cost          Decimal  @db.Decimal(12, 2)
  description   String
  completedById String   @db.Uuid
  completedBy   User     @relation(fields: [completedById], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())

  @@index([assetId])
  @@index([serviceDate])
  @@map("asset_maintenance_history")
}

// ── Dashboard ───────────────────────────────────────────────────
//
// createdBy / updatedBy audit fields may be introduced in a future phase if
// enhanced configuration auditing becomes a business requirement.

enum WidgetType {
  KPI
  CHART
  TABLE
  LIST
  CALENDAR
  METRIC
  CUSTOM
}

model Dashboard {
  id             String            @id @default(uuid()) @db.Uuid
  name           String
  code           String            @unique
  description    String?
  isDefault      Boolean           @default(false)
  enabled        Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  widgets        DashboardWidget[]
  userDashboards UserDashboard[]

  @@map("dashboards")
}

model DashboardWidget {
  id                     String    @id @default(uuid()) @db.Uuid
  dashboardId            String    @db.Uuid
  dashboard              Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  widgetKey              String
  title                  String
  widgetType             WidgetType
  configuration          Json
  row                    Int
  column                 Int
  width                  Int
  height                 Int
  refreshIntervalSeconds Int?
  visible                Boolean   @default(true)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@unique([dashboardId, widgetKey])
  @@index([dashboardId])
  @@index([widgetKey])
  @@index([visible])
  @@map("dashboard_widgets")
}

model UserDashboard {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  dashboardId  String    @db.Uuid
  dashboard    Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Restrict)
  isFavorite   Boolean   @default(false)
  isDefault    Boolean   @default(false)
  customLayout Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, dashboardId])
  @@index([userId])
  @@index([dashboardId])
  @@index([isFavorite])
  @@map("user_dashboards")
}

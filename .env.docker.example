# Docker Compose environment template — copy to `.env.docker` and fill secrets.
# Never commit `.env.docker` with real credentials.

# ── Compose / PostgreSQL ─────────────────────────────────────
POSTGRES_USER=rental
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=rental_erp
# Host port mapping (change if 5432 is already in use locally)
POSTGRES_PORT=5432
APP_PORT=3000

# ── Runtime / application ────────────────────────────────────
NODE_ENV=development
APP_ENV=local
APP_NAME=Rental ERP
APP_URL=http://localhost:3000
APP_LOCALE=en-PK
BETTER_AUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-at-least-32-character-secret
LOG_LEVEL=debug
UPLOAD_STORAGE=local
UPLOAD_PATH=/app/uploads
ENABLE_EMAIL=false
ENABLE_SMS=false
TIMEZONE=Asia/Karachi

# Built by Compose for the app service (host `db` is the Compose service name):
# DATABASE_URL=postgresql://rental:password@db:5432/rental_erp

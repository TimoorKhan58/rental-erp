# Staging environment template — copy to `.env.staging` (gitignored).
# Never commit real credentials.
#
# Typical pairing:
#   NODE_ENV=production   (Next.js production mode)
#   APP_ENV=staging       (staging operational safeguards)

# ── Runtime / deployment ─────────────────────────────────────
NODE_ENV=production
APP_ENV=staging

# ── Application ──────────────────────────────────────────────
APP_NAME=Rental ERP
APP_URL=https://staging.erp.example.com
APP_LOCALE=en-PK
TIMEZONE=Asia/Karachi

# ── Database (secret) ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@staging-db-host:5432/rental_erp_staging
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
BACKUP_DIR=/var/backups/rental-erp-staging
BACKUP_RETENTION_DAYS=7

# ── Authentication (secret) ──────────────────────────────────
# Generate a unique secret — placeholders are rejected in staging:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://staging.erp.example.com
AUTH_SESSION_EXPIRES_IN_SECONDS=604800
AUTH_SESSION_UPDATE_AGE_SECONDS=86400
AUTH_COOKIE_CACHE_MAX_AGE_SECONDS=300
AUTH_MIN_PASSWORD_LENGTH=8

# ── Security ─────────────────────────────────────────────────
TRUSTED_PROXIES=
SECURE_COOKIES=true
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
ERROR_TRACKER_PROVIDER=none

# ── Storage ──────────────────────────────────────────────────
UPLOAD_STORAGE=local
UPLOAD_PATH=./uploads
UPLOAD_MAX_FILE_SIZE_MB=10

# ── Cache ────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Email / SMTP ─────────────────────────────────────────────
ENABLE_EMAIL=false
ENABLE_SMS=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=true

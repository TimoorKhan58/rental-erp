# Environment variable template — copy to .env and fill in values.
# Do not commit .env or real credentials to Git.

# ── Application ──────────────────────────────────────────────
NODE_ENV="development"
APP_NAME="Rental ERP"
APP_URL="http://localhost:3000"

# ── Database ─────────────────────────────────────────────────
# PostgreSQL connection string (Neon, local Docker, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/rental_erp"

# ── Authentication (Better Auth) ───────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-character-secret"
BETTER_AUTH_URL="http://localhost:3000"

# ── Logging ──────────────────────────────────────────────────
# debug | info | warn | error (defaults: debug in development, info in production)
LOG_LEVEL="debug"

# ── Uploads ──────────────────────────────────────────────────
# local | s3
UPLOAD_STORAGE="local"
UPLOAD_PATH="./uploads"

# ── Email (future-ready) ─────────────────────────────────────
# Required only when ENABLE_EMAIL=true
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# ── Notifications ────────────────────────────────────────────
ENABLE_EMAIL="false"
ENABLE_SMS="false"

# ── General ──────────────────────────────────────────────────
TIMEZONE="UTC"

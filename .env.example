# Environment variable template — copy to .env and fill in values.
# Do not commit .env or real credentials to Git.
#
# See docs/production/ENVIRONMENT_VARIABLES.md for the full catalog.
# Deployment profiles: .env.staging.example · .env.production.example

# ── Runtime / deployment ─────────────────────────────────────
# NODE_ENV: development | test | production
NODE_ENV="development"
# APP_ENV: local | development | staging | production | test
# Controls hardened defaults (HTTPS, secure cookies, security headers).
APP_ENV="local"

# ── Application ──────────────────────────────────────────────
APP_NAME="Rental ERP"
APP_URL="http://localhost:3000"
APP_LOCALE="en-PK"
TIMEZONE="Asia/Karachi"
# Deprecated fallback (prefer APP_URL): NEXT_PUBLIC_APP_URL

# ── Database (secret) ────────────────────────────────────────
# PostgreSQL connection string (local Docker, Neon, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/rental_erp"
# Client-side pool (Prisma pg adapter). Prefer PgBouncer for large multi-instance fleets.
DATABASE_POOL_MAX="10"
DATABASE_POOL_IDLE_TIMEOUT_MS="30000"
DATABASE_POOL_CONNECTION_TIMEOUT_MS="5000"
# Operational backups (scripts/db/backup.*)
BACKUP_DIR="./backups"
BACKUP_RETENTION_DAYS="14"

# ── Authentication (secret) ──────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-at-least-32-character-secret"
BETTER_AUTH_URL="http://localhost:3000"
AUTH_SESSION_EXPIRES_IN_SECONDS="604800"
AUTH_SESSION_UPDATE_AGE_SECONDS="86400"
AUTH_COOKIE_CACHE_MAX_AGE_SECONDS="300"
AUTH_MIN_PASSWORD_LENGTH="8"

# ── Security ─────────────────────────────────────────────────
# Comma-separated proxy IPs/CIDRs trusted for X-Forwarded-* (optional)
TRUSTED_PROXIES=""
# Extra CSRF origins beyond APP_URL / BETTER_AUTH_URL (comma-separated)
# AUTH_TRUSTED_ORIGINS=""
# Auth rate limiting (Better Auth in-process; Nginx also limits /api/auth/)
AUTH_RATE_LIMIT_ENABLED="true"
# AUTH_RATE_LIMIT_WINDOW_SECONDS="60"
# AUTH_RATE_LIMIT_MAX="100"
# AUTH_RATE_LIMIT_SIGN_IN_WINDOW_SECONDS="60"
# AUTH_RATE_LIMIT_SIGN_IN_MAX="10"
# AUTH_RATE_LIMIT_PASSWORD_RESET_WINDOW_SECONDS="60"
# AUTH_RATE_LIMIT_PASSWORD_RESET_MAX="5"
# Defaults: false for local/dev, true for staging/production
# SECURE_COOKIES="false"
# ENABLE_SECURITY_HEADERS="false"
# ENABLE_HSTS="false"

# ── Logging ──────────────────────────────────────────────────
# debug | info | warn | error (default: debug local/dev, info staging/prod)
LOG_LEVEL="debug"
# json | pretty (default: pretty local/dev, json staging/prod)
LOG_FORMAT="pretty"

# ── Observability ────────────────────────────────────────────
# Prometheus scrape endpoint GET /api/metrics
ENABLE_METRICS="true"
# Optional: require Authorization: Bearer <token> for /api/metrics
# METRICS_BEARER_TOKEN=""
# none | sentry | datadog | newrelic | azure | otlp (SDK wiring is optional)
ERROR_TRACKER_PROVIDER="none"
# ERROR_TRACKER_DSN=""

# ── Storage ──────────────────────────────────────────────────
# local | s3  (s3 is not implemented — use local)
UPLOAD_STORAGE="local"
UPLOAD_PATH="./uploads"
UPLOAD_MAX_FILE_SIZE_MB="10"

# ── Cache ────────────────────────────────────────────────────
CACHE_TTL_SECONDS="300"

# ── Email / SMTP (secret: SMTP_PASSWORD) ─────────────────────
# Required only when ENABLE_EMAIL=true
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""
SMTP_SECURE="true"

# ── Feature flags / notifications ────────────────────────────
ENABLE_EMAIL="false"
ENABLE_SMS="false"

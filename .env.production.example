# Production environment template — copy to `.env.production` (gitignored).
# Never commit real credentials.
#
# Usage with Docker Compose + Nginx:
#   cp .env.production.example .env.production
#   # fill secrets, place TLS PEMs in nginx/certs/, then:
#   docker compose -f docker-compose.prod.yml --env-file .env.production up --build

# ── Compose / PostgreSQL (omit if using managed Postgres) ────
POSTGRES_USER=rental
POSTGRES_PASSWORD=
POSTGRES_DB=rental_erp

# ── Nginx / edge networking ──────────────────────────────────
NGINX_SERVER_NAME=erp.example.com
HTTP_PORT=80
HTTPS_PORT=443
# Place fullchain.pem + privkey.pem in nginx/certs/ (see nginx/certs/README.md)

# ── Runtime / deployment ─────────────────────────────────────
NODE_ENV=production
APP_ENV=production

# ── Application ──────────────────────────────────────────────
APP_NAME=Rental ERP
# Public HTTPS origin must match the certificate / NGINX_SERVER_NAME
APP_URL=https://erp.example.com
APP_LOCALE=en-PK
TIMEZONE=Asia/Karachi

# ── Database (secret) ────────────────────────────────────────
# Compose service hostname `db` when using the bundled Postgres service:
DATABASE_URL=postgresql://rental:password@db:5432/rental_erp
# Managed Postgres example:
# DATABASE_URL=postgresql://user:password@managed-host:5432/rental_erp?sslmode=require
DATABASE_POOL_MAX=10
DATABASE_POOL_IDLE_TIMEOUT_MS=30000
DATABASE_POOL_CONNECTION_TIMEOUT_MS=5000
BACKUP_DIR=/var/backups/rental-erp
BACKUP_RETENTION_DAYS=14

# ── Authentication (secret) ──────────────────────────────────
# Generate: openssl rand -base64 32
# Placeholder strings are rejected when APP_ENV=production.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://erp.example.com
AUTH_SESSION_EXPIRES_IN_SECONDS=604800
AUTH_SESSION_UPDATE_AGE_SECONDS=86400
AUTH_COOKIE_CACHE_MAX_AGE_SECONDS=300
AUTH_MIN_PASSWORD_LENGTH=8

# ── Security ─────────────────────────────────────────────────
# When Nginx terminates TLS, edge headers are applied by Nginx — keep app headers off
# to avoid duplicates (see docs/production/REVERSE_PROXY.md).
TRUSTED_PROXIES=
SECURE_COOKIES=true
ENABLE_SECURITY_HEADERS=false
ENABLE_HSTS=false

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
# METRICS_BEARER_TOKEN=
ERROR_TRACKER_PROVIDER=none
# ERROR_TRACKER_DSN=

# ── Storage ──────────────────────────────────────────────────
UPLOAD_STORAGE=local
UPLOAD_PATH=/app/uploads
UPLOAD_MAX_FILE_SIZE_MB=10

# ── Cache ────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300

# ── Email / SMTP ─────────────────────────────────────────────
ENABLE_EMAIL=false
ENABLE_SMS=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SECURE=true
